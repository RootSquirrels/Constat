# Copy to .env.local and fill in. Never commit .env.local.

# Backend API URL (server-side, used by the /api/proxy route handler).
# Same default as the dev API; override in prod.
CONSTAT_BACKEND_URL=http://localhost:8000

# Backend API key. The proxy injects this as X-API-Key on every
# forwarded request. NEVER set NEXT_PUBLIC_CONSTAT_API_KEY — the key
# would land in the browser bundle and leak.
# Required in prod: the proxy returns 503 if unset, so a misconfigured
# deploy fails loud instead of silently 401-ing every page.
CONSTAT_API_KEY=

# Legacy: NEXT_PUBLIC_API_URL is read at build time and is no longer
# used by browser-side fetches. Kept for any leftover client-side
# usage. Safe to remove once the audit confirms nothing reads it.
NEXT_PUBLIC_API_URL=http://localhost:8000

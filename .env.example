# Copy to .env and fill in. Never commit .env.
# Every variable below is actually read by the API (apps/api/src/constat_api/).
# Names are CONSTAT_*-prefixed; anything else is silently ignored.

# Postgres DSN (settings.py)
CONSTAT_DATABASE_URL=postgresql://constat:constat@localhost:5432/constat

# API key auth (auth.py). When set, every request except /health must
# send this value in the X-API-Key header.
# WARNING: when UNSET, auth is OPEN — anyone who can reach the API can
# call every endpoint. NEVER leave this unset outside local dev.
CONSTAT_API_KEY=

# Optional: RBAC-aware API keys (auth.py). Comma-separated
# name:role:key entries; role is "reader" (read endpoints only) or
# "operator" (everything: scans, rule runs, acks, retention actions).
# Example (keep commented out — real keys go in .env, never in git):
# CONSTAT_API_KEYS=alice:operator:change-me-alice,bob:reader:change-me-bob
# The legacy CONSTAT_API_KEY above remains a full operator key; the two
# sources union.
CONSTAT_API_KEYS=

# Optional: key for the /metrics scrape endpoint. When set, the scraper
# must send it in the X-Metrics-Key header. When unset, /metrics is open
# (trusted-network V1, same trust model as /health) and a warning is
# logged at startup.
CONSTAT_METRICS_KEY=

# Optional: allow manual insight creation via POST /insights (1/true/yes).
# Default OFF — real insights are written by the rule runner. Tests and
# local demos only; manual rows are stamped payload.source="manual".
CONSTAT_ENABLE_MANUAL_INSIGHTS=

# Optional: comma-separated CORS origins allowed by the API.
# Defaults to http://localhost:3000 when unset.
CONSTAT_CORS_ORIGINS=http://localhost:3000

# Optional: environment name. When set to anything other than "dev" and
# CONSTAT_API_KEY is unset, a loud warning is emitted at startup.
CONSTAT_ENV=dev

# Optional: 1/true/yes for JSON structured logs (prod); unset gives a
# colored console renderer (local dev).
CONSTAT_LOG_JSON=

# Optional: AWS CLI profile (~/.aws/credentials) used as the base session
# for AssumeRole in local dev. Leave unset in prod — the ECS/Fargate task
# role is picked up via the default credential chain.
CONSTAT_AWS_PROFILE=

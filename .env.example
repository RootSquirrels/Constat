# Copy to .env and fill in. Never commit .env.
# Every variable below is actually read by the API (apps/api/src/constat_api/).
# Names are CONSTAT_*-prefixed; anything else is silently ignored.

# Postgres DSN (settings.py)
CONSTAT_DATABASE_URL=postgresql://constat:constat@localhost:5432/constat

# API key auth (auth.py). When set, every request except /health must
# send this value in the X-API-Key header.
# WARNING: when UNSET, auth is OPEN — anyone who can reach the API can
# call every endpoint. NEVER leave this unset outside local dev.
CONSTAT_API_KEY=

# Optional: RBAC-aware API keys (auth.py). Comma-separated
# name:role:key[:tenant_uuid[:kind]] entries; role is "reader" (read
# endpoints only) or "operator" (everything: scans, rule runs, acks,
# retention actions). tenant_uuid scopes the key to a tenant (default:
# the built-in default tenant); kind is "machine" (default) or "human"
# (forward-looking, SSO). Example (keep commented out — real keys go in
# .env, never in git):
# CONSTAT_API_KEYS=alice:operator:change-me-alice,bot:reader:change-me-bot:00000000-0000-0000-0000-000000000002:machine
# The legacy CONSTAT_API_KEY above remains a full operator key on the
# default tenant; the two sources union.
CONSTAT_API_KEYS=

# Optional: key for the /metrics scrape endpoint. When set, the scraper
# must send it in the X-Metrics-Key header. When unset, /metrics is open
# (trusted-network V1, same trust model as /health) and a warning is
# logged at startup.
CONSTAT_METRICS_KEY=

# --- Async collection (POST /collect/aws -> 202 + worker) ---
# inline (default): in-process queue drained by a background pool in the
# API (dev/local). sqs: the API enqueues to SQS, an external worker
# service drains it (pilot/staging; requires CONSTAT_COLLECT_QUEUE_URL).
CONSTAT_COLLECT_MODE=inline
CONSTAT_COLLECT_QUEUE_URL=
# Max queued+in-flight items before POST /collect/aws answers 503
# (backpressure). Default 1000.
CONSTAT_COLLECT_QUEUE_MAXSIZE=1000
# Worker pool: total drain threads (default 4) and per-account cap
# (default 2 — AWS API quotas are per-account).
CONSTAT_WORKER_CONCURRENCY=4
CONSTAT_WORKER_PER_ACCOUNT=2
# 1 (default): the API process runs the inline drain pool. 0: never
# (tests; SQS mode never starts it regardless).
CONSTAT_WORKER_INLINE=1
# SQS receive visibility timeout in seconds; must exceed the slowest
# per-region scan or messages are redelivered mid-scan. Default 900.
CONSTAT_SQS_VISIBILITY_TIMEOUT=900

# Optional: allow manual insight creation via POST /insights (1/true/yes).
# Default OFF — real insights are written by the rule runner. Tests and
# local demos only; manual rows are stamped payload.source="manual".
CONSTAT_ENABLE_MANUAL_INSIGHTS=

# Optional: comma-separated CORS origins allowed by the API.
# Defaults to http://localhost:3000 when unset.
CONSTAT_CORS_ORIGINS=http://localhost:3000

# Optional: environment name. When set to anything other than "dev" and
# CONSTAT_API_KEY is unset, a loud warning is emitted at startup.
CONSTAT_ENV=dev

# Optional: 1/true/yes for JSON structured logs (prod); unset gives a
# colored console renderer (local dev).
CONSTAT_LOG_JSON=

# Optional: AWS CLI profile (~/.aws/credentials) used as the base session
# for AssumeRole in local dev. Leave unset in prod — the ECS/Fargate task
# role is picked up via the default credential chain.
CONSTAT_AWS_PROFILE=

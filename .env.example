# Copy to .env and fill in. Never commit .env.

# Postgres
DATABASE_URL=postgresql://constat:constat@localhost:5432/constat

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=constat
S3_SECRET_KEY=constat-secret
S3_BUCKET=constat-observations

# AWS (for live connector runs; leave empty for local dev)
AWS_ROLE_ARN=
AWS_EXTERNAL_ID=

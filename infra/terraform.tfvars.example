# Copy to terraform.tfvars and fill in. WARNING: the repo .gitignore does
# NOT yet cover *.tfvars / terraform state (2026-07-18) — never commit
# real values, and add the ignore entries (see infra/README.md) before
# the first apply. Prefer TF_VAR_* env vars for the sensitive ones.

aws_region     = "eu-west-3"
allowed_cidr   = "203.0.113.10/32" # operator/prospect egress IP — keep tight
image_tag      = "latest"
public_domain  = "pilot.constat.example.com" # update before go-live

# Sensitive — prefer `export TF_VAR_db_password=...` over writing here.
db_password     = "CHANGE-ME-long-random"
db_app_password = "CHANGE-ME-long-random"
api_key         = "CHANGE-ME-long-random"

# DEPRECATED (2026-07-19): no consumer left — the daily scan enqueues
# the persisted collect_targets (--enqueue-all) instead of reading a
# targets JSON. Still required as a variable until the deprecated
# scan_targets secret is removed (see secrets.tf); any JSON value works.
scan_targets_json = "[]"

# Empty = DLQ alarm exists but emails nobody (see variables.tf / sqs.tf).
# ops_alert_email = "ops@example.com"
